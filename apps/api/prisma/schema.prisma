// Workflo — Prisma schema
// Translated from docs/architecture.md §3 (Data Model). Do NOT run migrations
// here yet — no database is provisioned during scaffolding.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String
  avatarUrl     String?
  passwordHash  String? // null when OAuth-only
  createdAt     DateTime          @default(now())
  memberships   WorkspaceMember[]
  assigned      Issue[]           @relation("assignee")
  reported      Issue[]           @relation("reporter")
  comments      Comment[]
  refreshTokens RefreshToken[]
  views         View[]
  triageDismissals TriageDismissal[]
  triageSeen       TriageSeen[]
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  members   WorkspaceMember[]
  projects  Project[]
  views     View[]
  triageSeen TriageSeen[]
}

enum Role {
  OWNER
  MEMBER
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  role        Role      @default(MEMBER)

  @@unique([workspaceId, userId])
}

model Project {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  key         String // e.g. "WF" -> issues WF-123
  name        String
  createdAt   DateTime  @default(now())
  issues      Issue[]
  labels      Label[]
  counter     Int       @default(0) // monotonic per-project issue number

  @@unique([workspaceId, key])
}

enum IssueType {
  TASK
  BUG
  EPIC
}

enum IssueStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Issue {
  id           String                   @id @default(cuid())
  project      Project                  @relation(fields: [projectId], references: [id])
  projectId    String
  number       Int // human key = project.key + "-" + number
  title        String
  description  String? // rich text (JSON) later; markdown for MVP
  type         IssueType                @default(TASK)
  status       IssueStatus              @default(TODO)
  priority     Priority                 @default(MEDIUM)
  assignee     User?                    @relation("assignee", fields: [assigneeId], references: [id])
  assigneeId   String?
  reporter     User                     @relation("reporter", fields: [reporterId], references: [id])
  reporterId   String
  parent       Issue?                   @relation("epic", fields: [parentId], references: [id])
  parentId     String?
  children     Issue[]                  @relation("epic")
  labels       Label[]                  @relation("IssueLabels")
  rank         String // LexoRank-style string for board ordering
  dueDate      DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  comments     Comment[]

  @@unique([projectId, number])
  @@index([projectId, status, rank])
  // NLQ query engine perf indexes (docs/design/nlq-search.md §3.2) — support
  // the compiler's assignee/status, due-date range, and updated-date range
  // clauses without a full scan.
  @@index([assigneeId, status])
  @@index([projectId, dueDate])
  @@index([projectId, updatedAt])
  triageDismissals TriageDismissal[]
}

model Label {
  id        String  @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id])
  projectId String
  name      String
  color     String
  issues    Issue[] @relation("IssueLabels")

  @@unique([projectId, name])
}

model Comment {
  id        String   @id @default(cuid())
  issue     Issue    @relation(fields: [issueId], references: [id])
  issueId   String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  body      String
  mentions  String[] // userIds mentioned -> drives notifications
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // MENTION, ASSIGNED, STATUS_CHANGE...
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

// Opaque, rotated refresh tokens (ADR-0005). The token value itself is never
// stored — only a fast cryptographic hash (sha256) for lookup. `family`
// links a token to all of its rotated descendants so that reuse of a
// revoked token can invalidate the whole chain (theft detection).
model RefreshToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  family    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([family])
}

// Saved Views (docs/design/nlq-search.md §2.6/§3.5) — a named, stored
// WorkfloQuery AST. PERSONAL views are creator-only; WORKSPACE views are
// visible to every workspace member and editable by their creator OR the
// workspace OWNER (see apps/api/src/views/views.service.ts).
enum ViewScope {
  PERSONAL
  WORKSPACE
}

model View {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  creator     User      @relation(fields: [creatorId], references: [id])
  creatorId   String
  name        String
  scope       ViewScope @default(PERSONAL)
  ast         Json
  pinned      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, scope])
}

// Smart Triage (docs/design/nlq-search.md §2.7/§3.5) — per-user dismissals and
// last-visit tracking. `priorityAtDismiss`/`wasOverdueAtDismiss` are a
// deliberate addition beyond §3.5's literal model: §2.7 requires
// "auto-undismiss on escalation (priority raised or due arrives)", which is
// impossible to detect without a snapshot of the issue's state at dismiss
// time (see apps/api/src/triage/triage.service.ts).
enum TriageSection {
  OVERDUE
  GOING_STALE
  NEEDS_REPLY
  UNOWNED_URGENT
}

model TriageDismissal {
  id                  String        @id @default(cuid())
  user                User          @relation(fields: [userId], references: [id])
  userId              String
  issue               Issue         @relation(fields: [issueId], references: [id])
  issueId             String
  section             TriageSection
  until               DateTime
  /// Snapshot at dismiss time — powers auto-undismiss on escalation (§2.7).
  priorityAtDismiss   Priority
  wasOverdueAtDismiss Boolean       @default(false)
  createdAt           DateTime      @default(now())

  @@unique([userId, issueId, section])
  @@index([userId, until])
}

model TriageSeen {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  lastSeenAt  DateTime

  @@unique([userId, workspaceId])
}

