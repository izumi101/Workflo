# apps/api — env vars consumed by @workflo/api (see src/config/env.validation.ts)

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/workflo?schema=public"

# --- Redis (cache / pubsub / queues) ---
REDIS_URL="redis://localhost:6380"

# --- Auth ---
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# --- Google OAuth (optional in dev — leave blank to boot without Google sign-in) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# --- CORS (Vite dev server origin) ---
WEB_ORIGIN="http://localhost:5173"

# --- API server ---
PORT=3000
NODE_ENV="development"
